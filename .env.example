# Kakao Maps JavaScript SDK key (free).
# Issue at: https://developers.kakao.com  ->  My Application  ->  App Keys  ->  JavaScript key
# Copy this file to `.env` and fill in the value. If left empty, the map renders a placeholder fallback.
VITE_KAKAO_MAP_KEY=

# 백엔드 API 베이스 URL (예: http://localhost:8080/api). 미설정 시 '/api' 사용.
# VITE_API_PROXY_TARGET 을 쓰는 개발 환경에서는 '/api' 그대로 두면 됩니다.
VITE_API_BASE_URL=

# 앱 새로고침/초기 진입 때 연결 확인용으로 호출할 경로. 미설정 시 '/health_check' 사용.
VITE_API_HEALTH_PATH=/health_check

# 개발 서버 프록시 대상 (예: http://localhost:8080). 설정하면 API, uploads, health 요청을 전달합니다.
VITE_API_PROXY_TARGET=
